DEEPSEEK_API_KEY=your_deepseek_api_key
# Cheapest current DeepSeek API model in the docs.
DEEPSEEK_MODEL=deepseek-v4-flash
# Keep thinking disabled for this structured review task to reduce output tokens/cost.
DEEPSEEK_THINKING=disabled
DEEPSEEK_MAX_TOKENS=1200
# Optional. Default is https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Fallback / compatibility provider.
# MINIMAX_API_KEY=
# MINIMAX_MODEL=
# MINIMAX_BASE_URL=

# Optional: enables real document requests in /import-demo.
# Notion: create an Internal connection, copy its Installation access token,
# then grant the connection access to the page from Content access or
# the page menu: ... -> Connections -> Add connection.
# Tokens stay on the server and are never sent to the browser or committed.
# NOTION_IMPORT_ACCESS_TOKEN=
# Feishu Store App OAuth (recommended for /import-demo): create a Store App in
# Feishu Open Platform, enable the scopes documented in
# docs/FEISHU_IMPORT_AUTH_GUIDE.md, and register this redirect URL:
# http://localhost:3000/api/connectors/feishu/callback
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_REDIRECT_URI=http://localhost:3000/api/connectors/feishu/callback
# With no credentials, development uses Feishu's official dynamic app
# registration link. Set false to disable, or opt into the local fake flow.
# FEISHU_DYNAMIC_APP=true
# FEISHU_LOCAL_DEMO=false

# Optional fallback for a caller-managed user_access_token or tenant_access_token.
# FEISHU_IMPORT_ACCESS_TOKEN=
# FEISHU_API_BASE_URL=https://open.feishu.cn
# FEISHU_ACCOUNTS_BASE_URL=https://accounts.feishu.cn
# Official remote MCP used before the REST Block API fallback.
# FEISHU_MCP_SERVER_URL=https://mcp.feishu.cn/mcp

# Connect Notion uses the official hosted MCP server with OAuth + PKCE and
# dynamic client registration, so no Notion Client ID/Secret is required.
# NOTION_MCP_SERVER_URL=https://mcp.notion.com/mcp
# Development only: expose a second UI opt-in that stores the MCP credential
# bundle in this browser's localStorage. Production builds always disable it.
# NOTION_DEV_LOCAL_STORAGE=true

# YouMind uses a personal OpenAPI Key instead of third-party OAuth. The Demo can
# accept it from the connection UI and keep it in a 12-hour in-memory session.
# For server-managed / unattended import, generate a Key at
# https://youmind.com/settings/api-keys and configure it here instead.
# YOUMIND_IMPORT_API_KEY=sk-ym-xxx
# YOUMIND_API_BASE_URL=https://youmind.com/openapi/v1

# Google Docs personal import via Google Picker + non-sensitive drive.file.
# Enable Picker, Drive and Docs APIs. Add http://localhost:3000 as an authorized
# JavaScript origin, restrict the API key by referrer/API, and use the numeric
# Cloud Project Number as Picker App ID. No Client Secret or redirect URI needed.
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_PICKER_API_KEY=AIza...
# GOOGLE_CLOUD_PROJECT_NUMBER=123456789012
# GOOGLE_DOCS_API_BASE_URL=https://docs.googleapis.com/v1
# GOOGLE_DRIVE_API_BASE_URL=https://www.googleapis.com/drive/v3
